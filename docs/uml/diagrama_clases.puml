class ControlHardwareRoutes <<blueprint>> {
  +index()
  +guardar()
  +procesar_archivos()
  +api_estado()
  +api_comando()
  +api_evento()
}

class AreasRoutes <<blueprint>> {
  +index()
  +crear()
  +actualizar(area_id)
}

class HorariosRoutes <<blueprint>> {
  +index()
  +guardar()
}

