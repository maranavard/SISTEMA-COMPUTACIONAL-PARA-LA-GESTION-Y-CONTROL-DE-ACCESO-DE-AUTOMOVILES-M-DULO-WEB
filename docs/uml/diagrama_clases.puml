@startuml diagrama_clases
skinparam classAttributeIconSize 0

class User <<model>> {
  +id: int
  +username: str
  +password: str
  +rol: str
  +get_by_id(user_id): User
  +get_by_username(username): User
  +get_by_email(email): User
  +list_users(): list
  +create_user(...)
  +update_user(...)
  +update_password(...)
  +verify_password(candidate_password): bool
}

class Vehiculo <<model>> {
  +list_items(): list
  +get_by_id(item_id): dict
  +get_by_placa(placa): dict
  +create_item(data)
  +update_item(item_id, data)
  +delete_item(item_id)
  +get_document_status_by_placa(placa, warning_days): dict
}

class Novedad <<model>> {
  +list_recent(limit): list
  +register_ingreso_by_placa(placa, user_id): dict
  +register_salida_by_placa(placa, user_id, observaciones): int
  +create_reporte(payload): int
  -_assign_space_manual_fallback(placa, user_id): dict
  -_insert_ingreso_novedad(...)
}

class Espacio <<model>> {
  +list_items(): list
  +get_by_numero(numero): dict
  +get_by_id(item_id): dict
  +upsert_by_numero(data)
  +build_slots(total_slots): list
  +slot_summary(slots): dict
  +adapt_estado_for_db(requested_estado): tuple
}

class Visitante <<model>> {
  +list_items(): list
  +create_item(data)
  +update_item(item_id, data)
}

class Conductor <<model>> {
  +list_items(): list
  +create_item(data)
  +update_item(item_id, data)
}

class DocumentoVehiculo <<model>> {
  +upsert_documents(vehiculo_id, docs_expiration)
  +get_vehicle_documents(vehiculo_id): dict
  +get_status_summary(vehiculo_id, warning_days): dict
}

class AreaDestino <<model>> {
  +list_items(include_inactive): list
  +list_names(): list
  +create_area(nombre)
  +update_area(area_id, nombre)
  +delete_area(area_id)
}

class HorarioOperacion <<model>> {
  +get_config(): dict
  +update_config(hora_inicio, hora_fin, dias_activos, festivos_texto)
  +evaluate_moment(moment): dict
}

class ControlHardware <<model>> {
  +list_states(): list
  +update_states(state_map, user_id)
  +update_one(clave, encendido, user_id): bool
  +register_event(...): bool
  +list_recent_events(limit): list
}

class LocalSyncService <<service>> {
  +sync_event(entidad, operacion, payload): dict
  +retry_pending(limit): dict
  +enqueue_pending(entidad, operacion, payload, error_text)
  -_apply_to_local(entidad, operacion, payload)
  -_sync_vehiculo(local_conn, payload)
  -_sync_novedad(local_conn, payload)
}

class DB <<infra>> {
  +get_connection()
  +get_local_connection()
}

class AuthZ <<security>> {
  +normalize_role(role_value): str
  +roles_required(allowed_roles)
  +admin_required(view_func)
  +community_required(view_func)
  +parking_ops_required(view_func)
}

class AuthRoutes <<blueprint>> {
  +login()
  +login_post()
  +register()
  +register_post()
  +forgot_password()
  +reset_password(token)
  +logout()
}

class ControlAccesosRoutes <<blueprint>> {
  +index()
  +registrar_vehicular()
  +autorizacion()
  +autorizar(item_id)
  +rechazar(item_id)
  +historial()
}

class ReportesRoutes <<blueprint>> {
  +gestion()
  +visualizar(module_key)
  +imprimir(module_key)
  +descargar_excel(module_key)
}

class ConsultasRoutes <<blueprint>> {
  +index()
  +visualizar(item_id)
