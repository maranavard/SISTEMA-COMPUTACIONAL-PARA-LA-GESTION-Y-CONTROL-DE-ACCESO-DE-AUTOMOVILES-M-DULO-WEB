@startuml CU08_actividad_validar_acceso_vehicular
title CU08 Validar acceso vehicular
start
:Ingresar placa;
:Seleccionar entrada o salida;
if (Movimiento = entrada) then (Si)
  :Validar documentacion;
  if (Documentacion valida) then (Si)
    :Registrar ingreso y asignar cupo;
    :Notificar validacion;
  else (No)
    :Denegar acceso y mostrar motivo;
  endif
else (No)
  :Registrar salida;
  :Notificar validacion;
endif
stop
@enduml

