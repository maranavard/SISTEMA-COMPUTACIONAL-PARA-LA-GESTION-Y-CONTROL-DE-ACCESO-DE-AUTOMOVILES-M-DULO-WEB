@startuml CU15_gestionar_vehiculo_propio
actor "Usuario autenticado" as Usuario
participant "UI Web" as UI
participant "VehiculosRoutes" as V
participant "VehiculoModel" as M
database "PostgreSQL" as DB

Usuario -> UI : Consultar/editar vehiculo
UI -> V : POST guardar vehiculo
V -> V : validar permisos sensibles
alt Rol Administrador
	V -> M : create_item()/update_item()
	M -> DB : INSERT/UPDATE vehiculos
	DB --> M : ok/error
	M --> V : resultado
	V --> UI : mensaje de estado
else Otro rol
	V --> UI : solo consulta / operacion no permitida
end
@enduml
