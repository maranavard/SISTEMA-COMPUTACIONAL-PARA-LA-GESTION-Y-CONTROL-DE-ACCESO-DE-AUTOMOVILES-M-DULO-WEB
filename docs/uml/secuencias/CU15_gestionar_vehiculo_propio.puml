@startuml
actor Estudiante
participant "UI Web" as UI
participant "VehiculosRoutes" as V
participant "VehiculoModel" as M
database "PostgreSQL" as DB

Estudiante -> UI : Crear/editar vehiculo
UI -> V : POST guardar vehiculo
V -> M : create_item()/update_item()
M -> DB : INSERT/UPDATE vehiculos
DB --> M : ok/error
M --> V : resultado
V --> UI : mensaje de estado
@enduml
