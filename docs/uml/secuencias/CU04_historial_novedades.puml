@startuml CU04_historial_novedades
actor "Usuario autenticado" as Usuario
participant "UI Web" as UI
participant "NovedadesRoutes" as R
participant "NovedadModel" as N
database "PostgreSQL" as DB

Usuario -> UI : Definir filtros
UI -> R : GET historial con filtros
R -> R : validar rol y alcance
alt Rol Vigilante/Seguridad
	R -> R : limitar resultados al dia actual
end
R -> N : ejecutar busqueda filtrada
N -> DB : SELECT con filtros
DB --> N : registros
N --> R : historial
R --> UI : tabla de novedades
@enduml
