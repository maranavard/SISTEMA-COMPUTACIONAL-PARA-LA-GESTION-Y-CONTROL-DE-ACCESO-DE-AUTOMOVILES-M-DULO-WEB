@startuml CU02_consultar_reportes
actor "Administrador o Vigilante" as Actor
participant "UI Web" as UI
participant "ReportesRoutes" as R
participant "NovedadModel/VehiculoModel" as M
database "PostgreSQL" as DB

Actor -> UI : Seleccionar tipo de reporte
UI -> R : GET /reportes/modulo/{tipo}
R -> R : validar permisos por rol
alt Actor es Vigilante
	R -> R : forzar modulo accesos_salidas del dia
end
R -> M : cargar datos del reporte
M -> DB : SELECT datos consolidados
DB --> M : resultados
M --> R : dataset
R --> UI : render reporte
@enduml
