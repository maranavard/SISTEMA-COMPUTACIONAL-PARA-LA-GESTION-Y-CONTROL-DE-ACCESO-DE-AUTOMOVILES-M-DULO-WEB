@startuml CU18_consultar_estado_visitante_funcionario
actor "Administrador o Vigilante" as Actor
participant "UI Web" as UI
participant "ControlAccesosRoutes" as R
participant "VisitanteModel" as V
database "PostgreSQL" as DB

Actor -> UI : Consultar estado de solicitudes
UI -> R : GET /control-accesos/autorizacion
R -> V : list_items() y filtrar pendientes
V -> DB : SELECT solicitudes
DB --> V : resultados
V --> R : estado de solicitud
R --> UI : mostrar estado
@enduml
