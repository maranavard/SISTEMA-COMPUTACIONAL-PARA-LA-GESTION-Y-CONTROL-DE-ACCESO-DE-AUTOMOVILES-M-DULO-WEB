FLASK_ENV=development
SECRET_KEY=cambia-esta-clave
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sistema_control
DB_USER=postgres
DB_PASSWORD=postgres

# RF18 - Sincronización Web <-> Local
LOCAL_DB_ENABLED=1
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=sistema_control_local
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=postgres
SYNC_MAX_RETRIES=10

# RF08 - Recuperación de contraseña por correo
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu_correo@dominio.com
MAIL_PASSWORD=tu_clave_o_app_password
MAIL_FROM=tu_correo@dominio.com
MAIL_USE_TLS=1

# Modo prueba: no envía correo real; muestra enlace en pantalla y consola
MAIL_SUPPRESS_SEND=1

# Seguridad token recuperación
PASSWORD_RESET_SALT=password-reset-salt
PASSWORD_RESET_MAX_AGE_SECONDS=3600
